# Local dev: point at your local API (no trailing slash).
# ESP32 devices POST to: {NEXT_PUBLIC_API_URL}/data
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# --- Vercel + Render (recommended production) ---
# Dashboard on Vercel, API on Render (HTTPS). In Vercel → Environment Variables:
#   NEXT_PUBLIC_API_URL=https://sliot-backend.onrender.com
# ESP32 firmware: POST https://sliot-backend.onrender.com/data
#
# Optional proxy mode (if you use next.config rewrites):
#   BACKEND_PROXY_URL=https://sliot-backend.onrender.com
#   NEXT_PUBLIC_API_URL=/backend-api
#
# WebSocket alerts on HTTPS pages need wss:// on the API host:
#   NEXT_PUBLIC_WS_URL=wss://sliot-backend.onrender.com
